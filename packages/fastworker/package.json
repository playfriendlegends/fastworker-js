{
  "name": "fastworker-js",
  "version": "0.1.6",
  "description": "Platform-agnostic stateless modular monolith framework — types, compiler, router, RPC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./compiler": {
      "types": "./dist/compiler.d.ts",
      "import": "./dist/compiler.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "bin": {
    "fastworker": "./dist/cli-entry.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "framework",
    "modular-monolith",
    "rpc",
    "file-system-routing",
    "microservices",
    "edge"
  ],
  "license": "MIT"
}
