{
  "name": "fastworker-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "fastworker — Platform-Agnostic Stateless Modular Monolith Framework",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "rm -rf packages/*/dist examples/*/dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "webpack": "5.104.0"
  },
  "license": "MIT"
}
